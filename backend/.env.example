DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Browser origins allowed to call this API (comma-separated, no spaces).
# Cloudflare Pages: https://your-app.pages.dev
# Custom domain: https://crm.yourdomain.com
# Tunnel (cloudflared): https://api-xxxxx.trycloudflare.com
# Local dev: http://127.0.0.1:3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
